# JWT for the 1Click Swap API (https://partners.near-intents.org).
# Server-side only — MUST never appear in any challenge field or client code.
# Unauthenticated requests work but incur a 0.2% fee (demos only).
ONE_CLICK_JWT=

# --- examples/server.ts ---
# Challenge-HMAC secret, ≥32 bytes (a dev-only default is built in).
MPP_SECRET_KEY=
# NEAR account that receives the funds (defaults to the "merchant.near" placeholder).
MERCHANT_RECIPIENT=
# Merchant refund addresses on each supported origin chain.
REFUND_TO_ARB=
REFUND_TO_BTC=

# --- examples/client.ts (real funds!) ---
# Funded Arbitrum account key for the built-in EVM broadcast.
PRIVATE_KEY=
# Or: hash of a deposit you already broadcast yourself.
DEPOSIT_TX_HASH=
