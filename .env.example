# JWT for the 1Click Swap API (https://partners.near-intents.org).
# Server-side only — MUST never appear in any challenge field or client code.
# Unauthenticated requests work but incur a 0.2% fee (demos only).
ONE_CLICK_JWT=

# --- examples/server.ts ---
# Challenge-HMAC secret, ≥32 bytes (a dev-only default is built in).
MPP_SECRET_KEY=
# NEAR account that receives the funds (defaults to the "merchant.near" placeholder).
MERCHANT_RECIPIENT=
# Custodial merchant fallback addresses. Production payer-controlled flows
# should use charge({ refundTo: resolver }) as documented in the README.
REFUND_TO_ARB=
REFUND_TO_BTC=

# --- examples/client.ts (real funds!) ---
# Funded Arbitrum account key for the built-in EVM broadcast.
PRIVATE_KEY=
# Or: hash of a deposit you already broadcast yourself.
DEPOSIT_TX_HASH=

# --- scripts/live-oneclick-smoke.ts (manual, REAL FUNDS; never CI) ---
# Safety switch required by `pnpm smoke:live`.
LIVE_ONE_CLICK=
# Quote phase: CAIP-19 assets, base-unit exact output, and payer-controlled refund address.
LIVE_ORIGIN_ASSET=
LIVE_DESTINATION_ASSET=
LIVE_AMOUNT_OUT=
LIVE_DESTINATION_RECIPIENT=
LIVE_REFUND_TO=
# Settlement phase: copy the quote's deposit address/memo after broadcasting externally.
LIVE_DEPOSIT_ADDRESS=
LIVE_DEPOSIT_MEMO=
LIVE_DEPOSIT_TX_HASH=
# Optional: SUCCESS (default), REFUNDED, FAILED, or INCOMPLETE_DEPOSIT.
LIVE_EXPECT_STATUS=
